                                            LineEdit { text <=> root.room-id; placeholder-text: "直播间 ID"; }
                                            Text { text: "进房弹幕"; color: root.muted-color; font-size: 11px; font-weight: 700; }
                                            LineEdit { text <=> root.entry-msg; }
                                            Text { text: "下播公告"; color: root.muted-color; font-size: 11px; font-weight: 700; }
                                            LineEdit { text <=> root.goodbye-info; }
                                            Text { text: "弹幕长度"; color: root.muted-color; font-size: 11px; font-weight: 700; }
                                            SpinBox { value <=> root.danmu-len; minimum: 1; maximum: 100; }
                                        }

                                        VerticalLayout {
                                            spacing: 8px;
                                            Text { text: "自动化开关"; color: root.text-color; font-size: 13px; font-weight: 800; }
                                            CheckBox { text: "PK 提醒"; checked <=> root.pk-notice; }
                                            CheckBox { text: "欢迎"; checked <=> root.welcome-enabled; }
                                            CheckBox { text: "特效欢迎"; checked <=> root.entry-effect; }
                                            CheckBox { text: "礼物答谢"; checked <=> root.thanks-gift; }
                                            CheckBox { text: "关注答谢"; checked <=> root.thanks-focus; }
                                            CheckBox { text: "分享答谢"; checked <=> root.thanks-share; }
                                            CheckBox { text: "定时弹幕"; checked <=> root.cron-danmu; }
                                            CheckBox { text: "关键词回复"; checked <=> root.keyword-reply; }
                                            CheckBox { text: "弹幕过滤"; checked <=> root.danmu-filter-enable; }
                                            CheckBox { text: "新人发言提示"; checked <=> root.newcomer-danmu-enable; }
                                            CheckBox { text: "礼物总结答谢"; checked <=> root.gift-summary-thanks; }
                                        }

