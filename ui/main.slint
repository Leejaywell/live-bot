import { CheckBox, ComboBox, LineEdit, ScrollView, SpinBox, TextEdit } from "std-widgets.slint";

component ActionButton inherits Rectangle {
    in property <string> label;
    in property <bool> primary: false;
    in property <bool> enabled: true;
    in property <color> accent;
    in property <color> fill;
    in property <color> text-color;
    in property <color> line-color;
    callback clicked();

    height: 40px;
    border-radius: 14px;
    background: !root.enabled ? root.line-color : (root.primary ? root.accent : root.fill);
    border-width: root.primary ? 0px : 1px;
    border-color: root.primary ? root.accent : root.line-color;

    Text {
        text: root.label;
        color: !root.enabled ? #94a3b8 : (root.primary ? #ffffff : root.text-color);
        font-size: 12px;
        font-weight: 800;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
    }
}

component SidebarEntry inherits Rectangle {
    in property <string> icon;
    in property <string> title;
    in property <string> subtitle;
    in property <string> badge: "";
    in property <bool> active: false;
    in property <color> accent;
    in property <color> base-bg;
    in property <color> text-color;
    in property <color> muted-color;
    in property <color> outline-color;

    height: 54px;
    border-radius: 14px;
    background: root.active ? root.accent : root.base-bg;
    border-width: root.active ? 0px : 1px;
    border-color: root.active ? root.accent : root.outline-color;

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        padding-top: 8px;
        padding-bottom: 8px;
        spacing: 10px;

        Rectangle {
            width: 34px;
            height: 34px;
            border-radius: 10px;
            background: root.active ? #ffffff22 : root.accent;

            Text {
                text: root.icon;
                color: #ffffff;
                font-size: 12px;
                font-weight: 800;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        VerticalLayout {
            spacing: 1px;
            Text {
                text: root.title;
                color: root.active ? #ffffff : root.text-color;
                font-size: 13px;
                font-weight: 800;
            }
            Text {
                text: root.subtitle;
                color: root.active ? #dbeafe : root.muted-color;
                font-size: 11px;
            }
        }

        Rectangle { }

        if root.badge != "" : Rectangle {
            width: 48px;
            height: 20px;
            border-radius: 10px;
            background: root.active ? #ffffff22 : root.accent;

            Text {
                text: root.badge;
                color: #ffffff;
                font-size: 10px;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }
}

component StatusCard inherits Rectangle {
    in property <string> label;
    in property <string> value;
    in property <string> icon;
    in property <color> accent;
    in property <color> base-bg;
    in property <color> outline-color;
    in property <color> text-color;
    in property <color> muted-color;

    border-radius: 18px;
    border-width: 1px;
    border-color: root.outline-color;
    background: root.base-bg;

    VerticalLayout {
        padding: 16px;
        spacing: 10px;

        HorizontalLayout {
            Text {
                text: root.label;
                color: root.muted-color;
                font-size: 12px;
                font-weight: 700;
            }
            Rectangle { }
            Rectangle {
                width: 30px;
                height: 30px;
                border-radius: 10px;
                background: root.accent;

                Text {
                    text: root.icon;
                    color: #ffffff;
                    font-size: 11px;
                    font-weight: 800;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }

        Text {
            text: root.value;
            color: root.text-color;
            font-size: 18px;
            font-weight: 800;
        }
    }
}

component FeatureCard inherits Rectangle {
    in property <string> title;
    in property <string> desc;
    in property <string> meta;
    in property <bool> enabled: true;
    in property <color> accent;
    in property <color> base-bg;
    in property <color> outline-color;
    in property <color> text-color;
    in property <color> muted-color;

    border-radius: 16px;
    border-width: 1px;
    border-color: root.outline-color;
    background: root.base-bg;

    HorizontalLayout {
        padding: 14px;
        spacing: 12px;

        Rectangle {
            width: 38px;
            height: 22px;
            border-radius: 11px;
            background: root.enabled ? root.accent : root.border-color;

            Rectangle {
                y: 3px;
                x: root.enabled ? 19px : 3px;
                width: 16px;
                height: 16px;
                border-radius: 8px;
                background: #ffffff;
            }
        }

        VerticalLayout {
            spacing: 4px;
            HorizontalLayout {
                spacing: 8px;
                Text {
                    text: root.title;
                    color: root.text-color;
                    font-size: 13px;
                    font-weight: 800;
                }
                if root.enabled : Rectangle {
                    width: 34px;
                    height: 18px;
                    border-radius: 9px;
                    background: root.accent;

                    Text {
                        text: "启用";
                        color: #ffffff;
                        font-size: 9px;
                        font-weight: 700;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
            Text {
                text: root.desc;
                color: root.muted-color;
                font-size: 11px;
            }
            Text {
                text: root.meta;
                color: root.accent;
                font-size: 11px;
                font-weight: 700;
            }
        }
    }
}

component PlanCard inherits Rectangle {
    in property <string> title;
    in property <string> desc;
    in property <string> tags;
    in property <color> accent;
    in property <color> base-bg;
    in property <color> outline-color;
    in property <color> text-color;
    in property <color> muted-color;

    border-radius: 16px;
    border-width: 1px;
    border-color: root.outline-color;
    background: root.base-bg;

    VerticalLayout {
        padding: 14px;
        spacing: 8px;

        HorizontalLayout {
            Text {
                text: root.title;
                color: root.text-color;
                font-size: 13px;
                font-weight: 800;
            }
            Rectangle { }
            Rectangle {
                width: 44px;
                height: 18px;
                border-radius: 9px;
                background: root.accent;

                Text {
                    text: "规划中";
                    color: #ffffff;
                    font-size: 9px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }

        Text {
            text: root.desc;
            color: root.muted-color;
            font-size: 11px;
            wrap: word-wrap;
        }

        Rectangle {
            height: 28px;
            border-radius: 10px;
            background: root.border-color;

            Text {
                text: root.tags;
                color: root.muted-color;
                font-size: 10px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }
}

component ThemeSwatch inherits Rectangle {
    in property <color> swatch;
    in property <string> label;
    in property <bool> selected: false;
    in property <color> fill;
    in property <color> text-color;
    in property <color> line-color;
    callback activate();

    height: 70px;
    border-radius: 14px;
    border-width: 1px;
    border-color: root.selected ? root.swatch : root.line-color;
    background: root.fill;

    VerticalLayout {
        padding: 8px;
        spacing: 6px;

        Rectangle {
            height: 34px;
            border-radius: 10px;
            background: root.swatch;

            if root.selected : Text {
                text: "OK";
                color: #ffffff;
                font-size: 10px;
                font-weight: 800;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        Text {
            text: root.label;
            color: root.text-color;
            font-size: 10px;
            horizontal-alignment: center;
        }
    }

    TouchArea {
        clicked => { root.activate(); }
    }
}

export component MainWindow inherits Window {
    title: "Bilibili Danmu Robot";
    width: 1560px;
    height: 980px;

    in-out property <string> room-id: "8792912";
    in-out property <int> danmu-len: 20;
    in-out property <string> entry-msg: "花花机器人进入直播间";
    in-out property <string> goodbye-info: "下播啦~ 感谢大家的陪伴~ 下次见哦~";
    in-out property <bool> pk-notice: true;
    in-out property <bool> welcome-enabled: true;
    in-out property <bool> entry-effect: true;
    in-out property <bool> thanks-gift: true;
    in-out property <bool> thanks-focus: true;
    in-out property <bool> thanks-share: true;
    in-out property <bool> cron-danmu: false;
    in-out property <bool> keyword-reply: false;
    in-out property <bool> draw-by-lot: true;
    in-out property <bool> sign-in-enable: true;
    in-out property <bool> danmu-filter-enable: false;
    in-out property <string> danmu-filter-words-text: "";
    in-out property <int> danmu-filter-repeat-threshold: 3;
    in-out property <string> gift-aliases-text: "";
    in-out property <string> gift-thanks-templates-text: "";
    in-out property <bool> gift-summary-thanks: false;
    in-out property <string> gift-summary-template: "本轮共收到{count}件礼物，价值{value}电池";
    in-out property <bool> newcomer-danmu-enable: false;
    in-out property <string> newcomer-danmu-template: "欢迎新朋友 {user} 首次发言";
    in-out property <string> permanent-blacklist-users-text: "";
    in-out property <string> permanent-blacklist-names-text: "";
    in-out property <string> special-nicknames-text: "";
    in-out property <string> robot-name: "花花";
    in-out property <string> talk-robot-cmd: "花花";
    in-out property <int> robot-mode-index: 0;
    in-out property <string> chatgpt-token: "";
    in-out property <string> chatgpt-api-url: "";
    in-out property <string> chatgpt-prompt: "你是一个非常幽默的机器人助理，可以使用emoji表情，可以使用颜文字";
    in-out property <string> welcome-list-text: "";
    in-out property <string> focus-list-text: "";
    in-out property <string> blacklist-wide-text: "";
    in-out property <string> blacklist-exact-text: "";
    in-out property <string> keyword-reply-text: "";
    in-out property <string> cron-danmu-text: "";
    in-out property <string> draw-list-text: "";
    in-out property <string> manual-danmu: "";
    in-out property <string> login-url: "";
    in-out property <string> user-info: "夜莺工作室";
    in-out property <string> room-status: "8792912 / 直播中";
    in-out property <string> run-status: "运行中";
    in-out property <string> update-link: "";
    in-out property <string> log-text: "";

    in-out property <bool> theme-popup-open: true;
    in-out property <bool> dark-mode: false;
    in-out property <int> theme-choice: 0;

    property <color> theme-primary:
        root.theme-choice == 0 ? #0ea5e9 :
        root.theme-choice == 1 ? #10b981 :
        root.theme-choice == 2 ? #f97316 :
        root.theme-choice == 3 ? #ec4899 :
        root.theme-choice == 4 ? #64748b :
        root.theme-choice == 5 ? #f59e0b :
        root.theme-choice == 6 ? #8b5cf6 :
        root.theme-choice == 7 ? #ef4444 :
        root.theme-choice == 8 ? #14b8a6 :
        root.theme-choice == 9 ? #a855f7 :
        root.theme-choice == 10 ? #22c55e :
        #2563eb;

    property <color> app-bg: root.dark-mode ? #0a0f16 : #eef4fb;
    property <color> panel-bg: root.dark-mode ? #121823 : #fcfdff;
    property <color> panel-soft-bg: root.dark-mode ? #19202c : #f6f9fd;
    property <color> panel-strong-bg: root.dark-mode ? #0d131c : #101826;
    property <color> line-color: root.dark-mode ? #273142 : #dbe4f0;
    property <color> text-color: root.dark-mode ? #f4f7fb : #0f172a;
    property <color> muted-color: root.dark-mode ? #9fb0c5 : #526072;
    property <color> card-alt-bg: root.dark-mode ? #161f2b : #f7fafe;
    property <color> success-bg: root.dark-mode ? #173225 : #ecfdf5;
    property <color> success-text: root.dark-mode ? #7bf1b6 : #047857;
    property <color> warning-bg: root.dark-mode ? #3a2812 : #fff7ed;
    property <color> warning-text: root.dark-mode ? #f7bc69 : #9a3412;
    property <color> popup-bg: root.dark-mode ? #11151c : #ffffff;

    callback load-config();
    callback save-config(
        string, int, string, string,
        bool, bool, bool, bool, bool, bool, bool, bool, bool, bool, bool,
        string, int, string, string, bool, string, bool, string, string, string, string, string, string, int,
        string, string, string, string, string, string, string, string, string, string
    );
    callback start-login();
    callback check-login();
    callback check-room();
    callback start-monitor();
    callback stop-monitor();
    callback send-danmu(string);
    callback check-update();
    callback download-update(string);

    background: root.app-bg;

    Rectangle {
        background: root.app-bg;

        HorizontalLayout {
            spacing: 0px;

            Rectangle {
                width: 256px;
                background: root.panel-bg;
                border-width: 1px;
                border-color: root.line-color;

                VerticalLayout {
                    padding-left: 16px;
                    padding-right: 16px;
                    padding-top: 18px;
                    padding-bottom: 18px;
                    spacing: 12px;

                    HorizontalLayout {
                        spacing: 10px;
                        Rectangle {
                            width: 40px;
                            height: 40px;
                            border-radius: 12px;
                            background: root.theme-primary;

                            Text {
                                text: "LB";
                                color: #ffffff;
                                font-size: 13px;
                                font-weight: 900;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                        VerticalLayout {
                            spacing: 2px;
                            Text { text: "Live Bot"; color: root.text-color; font-size: 18px; font-weight: 900; }
                            Text { text: "直播运营助手"; color: root.muted-color; font-size: 11px; font-weight: 700; }
                        }
                    }

                    Rectangle { height: 1px; background: root.line-color; }

                    Text { text: "工作区"; color: root.muted-color; font-size: 11px; font-weight: 800; }
                    SidebarEntry { icon: "总"; title: "总览"; subtitle: "运营中心"; active: true; accent: root.theme-primary; base-bg: root.panel-soft-bg; text-color: root.text-color; muted-color: root.muted-color; outline-color: root.line-color; }
                    SidebarEntry { icon: "登"; title: "登录与房间"; subtitle: "账号管理"; accent: root.theme-primary; base-bg: root.panel-soft-bg; text-color: root.text-color; muted-color: root.muted-color; outline-color: root.line-color; }
                    SidebarEntry { icon: "听"; title: "监听与发送"; subtitle: "弹幕控制"; accent: root.theme-primary; base-bg: root.panel-soft-bg; text-color: root.text-color; muted-color: root.muted-color; outline-color: root.line-color; }
                    SidebarEntry { icon: "规"; title: "自动回复规则"; subtitle: "互动策略"; accent: root.theme-primary; base-bg: root.panel-soft-bg; text-color: root.text-color; muted-color: root.muted-color; outline-color: root.line-color; }
                    SidebarEntry { icon: "AI"; title: "AI 机器人"; subtitle: "智能对话"; accent: root.theme-primary; base-bg: root.panel-soft-bg; text-color: root.text-color; muted-color: root.muted-color; outline-color: root.line-color; }
                    SidebarEntry { icon: "数"; title: "数据统计"; subtitle: "运营分析"; accent: root.theme-primary; base-bg: root.panel-soft-bg; text-color: root.text-color; muted-color: root.muted-color; outline-color: root.line-color; }
                    SidebarEntry { icon: "PK"; title: "PK 与活动"; subtitle: "赛事管理"; accent: root.theme-primary; base-bg: root.panel-soft-bg; text-color: root.text-color; muted-color: root.muted-color; outline-color: root.line-color; }
                    SidebarEntry { icon: "房"; title: "直播间管理"; subtitle: "房间配置"; badge: "规划中"; accent: root.theme-primary; base-bg: root.panel-soft-bg; text-color: root.text-color; muted-color: root.muted-color; outline-color: root.line-color; }
                    SidebarEntry { icon: "扩"; title: "高级扩展"; subtitle: "插件生态"; badge: "规划中"; accent: root.theme-primary; base-bg: root.panel-soft-bg; text-color: root.text-color; muted-color: root.muted-color; outline-color: root.line-color; }
                    SidebarEntry { icon: "录"; title: "录播与素材"; subtitle: "内容存档"; badge: "规划中"; accent: root.theme-primary; base-bg: root.panel-soft-bg; text-color: root.text-color; muted-color: root.muted-color; outline-color: root.line-color; }
                    SidebarEntry { icon: "系"; title: "系统与更新"; subtitle: "版本管理"; accent: root.theme-primary; base-bg: root.panel-soft-bg; text-color: root.text-color; muted-color: root.muted-color; outline-color: root.line-color; }

                    Rectangle { height: 1px; background: root.line-color; }

                    Rectangle {
                        height: 74px;
                        border-radius: 16px;
                        background: root.panel-strong-bg;

                        VerticalLayout {
                            padding: 12px;
                            spacing: 4px;
                            Text {
                                text: root.run-status == "运行中" ? "监听正在运行" : "监听未启动";
                                color: #f8fafc;
                                font-size: 13px;
                                font-weight: 900;
                            }
                            Text {
                                text: "房间 " + root.room-id + " · " + root.room-status;
                                color: #cbd5e1;
                                font-size: 11px;
                            }
                            Text {
                                text: "主题弹窗默认展开，可即时切换亮暗与配色";
                                color: #93c5fd;
                                font-size: 10px;
                            }
                        }
                    }
                }
            }

            VerticalLayout {
                spacing: 0px;

                Rectangle {
                    height: 68px;
                    background: root.panel-bg;
                    border-width: 1px;
                    border-color: root.line-color;

                    HorizontalLayout {
                        padding-left: 22px;
                        padding-right: 22px;
                        padding-top: 14px;
                        padding-bottom: 14px;
                        spacing: 16px;

                        VerticalLayout {
                            spacing: 2px;
                            Text { text: "直播间 #" + root.room-id; color: root.text-color; font-size: 16px; font-weight: 900; }
                            Text { text: "主播账号: " + root.user-info; color: root.muted-color; font-size: 12px; }
                        }

                        Rectangle { width: 1px; background: root.line-color; }

                        Rectangle {
                            width: 96px;
                            height: 34px;
                            border-radius: 17px;
                            background: root.run-status == "运行中" ? root.success-bg : root.warning-bg;
                            border-width: 1px;
                            border-color: root.run-status == "运行中" ? root.success-text : root.warning-text;

                            Text {
                                text: root.run-status;
                                color: root.run-status == "运行中" ? root.success-text : root.warning-text;
                                font-size: 12px;
                                font-weight: 800;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }

                        Rectangle { }

                        Rectangle {
                            width: 280px;
                            height: 40px;
                            border-radius: 14px;
                            background: root.card-alt-bg;
                            border-width: 1px;
                            border-color: root.line-color;

                            LineEdit {
                                text: "";
                                placeholder-text: "搜索功能或执行命令...";
                                x: 12px;
                                y: 8px;
                                width: parent.width - 24px;
                                height: 24px;
                            }
                        }

                        Rectangle {
                            width: 42px;
                            height: 42px;
                            border-radius: 14px;
                            background: root.card-alt-bg;
                            border-width: 1px;
                            border-color: root.line-color;

                            Text {
                                text: "调";
                                color: root.text-color;
                                font-size: 13px;
                                font-weight: 900;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }

                            TouchArea {
                                clicked => {
                                    root.theme-popup-open = !root.theme-popup-open;
                                }
                            }
                        }
                    }
                }

                HorizontalLayout {
                    spacing: 18px;
                    padding: 18px;

                    ScrollView {
                        width: 950px;

                        VerticalLayout {
                            spacing: 16px;

                            Text { text: "运营总览"; color: root.text-color; font-size: 20px; font-weight: 900; }
                            Text { text: "实时监控直播间状态、规则运行情况和互动数据"; color: root.muted-color; font-size: 12px; }

                            HorizontalLayout {
                                spacing: 12px;
                                StatusCard { width: 220px; height: 92px; label: "登录状态"; value: "已登录"; icon: "登"; accent: #10b981; base-bg: root.panel-bg; outline-color: root.line-color; text-color: root.text-color; muted-color: root.muted-color; }
                                StatusCard { width: 220px; height: 92px; label: "房间状态"; value: "直播中"; icon: "房"; accent: #10b981; base-bg: root.panel-bg; outline-color: root.line-color; text-color: root.text-color; muted-color: root.muted-color; }
                                StatusCard { width: 220px; height: 92px; label: "监听状态"; value: root.run-status; icon: "听"; accent: root.theme-primary; base-bg: root.panel-bg; outline-color: root.line-color; text-color: root.text-color; muted-color: root.muted-color; }
                                StatusCard { width: 220px; height: 92px; label: "WebSocket"; value: "已连接"; icon: "WS"; accent: root.theme-primary; base-bg: root.panel-bg; outline-color: root.line-color; text-color: root.text-color; muted-color: root.muted-color; }
                            }

                            HorizontalLayout {
                                spacing: 12px;
                                StatusCard { width: 220px; height: 92px; label: "AI 状态"; value: "就绪"; icon: "AI"; accent: #8b5cf6; base-bg: root.panel-bg; outline-color: root.line-color; text-color: root.text-color; muted-color: root.muted-color; }
                                StatusCard { width: 220px; height: 92px; label: "发送队列"; value: "3 条"; icon: "发"; accent: #f59e0b; base-bg: root.panel-bg; outline-color: root.line-color; text-color: root.text-color; muted-color: root.muted-color; }
                                StatusCard { width: 220px; height: 92px; label: "今日弹幕数"; value: "1247"; icon: "弹"; accent: #06b6d4; base-bg: root.panel-bg; outline-color: root.line-color; text-color: root.text-color; muted-color: root.muted-color; }
                                StatusCard { width: 220px; height: 92px; label: "更新状态"; value: "有新版本"; icon: "更"; accent: #ec4899; base-bg: root.panel-bg; outline-color: root.line-color; text-color: root.text-color; muted-color: root.muted-color; }
                            }

                            Rectangle {
                                background: root.panel-bg;
                                border-radius: 20px;
                                border-width: 1px;
                                border-color: root.line-color;

                                VerticalLayout {
                                    padding: 18px;
                                    spacing: 14px;

                                    Text { text: "快速操作"; color: root.text-color; font-size: 16px; font-weight: 900; }

                                    HorizontalLayout {
                                        spacing: 10px;
                                        ActionButton { label: "生成登录链接"; primary: true; accent: root.theme-primary; fill: root.card-alt-bg; text-color: root.text-color; line-color: root.line-color; clicked => { root.start-login(); } }
                                        ActionButton { label: "检查登录"; accent: root.theme-primary; fill: root.card-alt-bg; text-color: root.text-color; line-color: root.line-color; clicked => { root.check-login(); } }
                                        ActionButton { label: "检测房间"; accent: root.theme-primary; fill: root.card-alt-bg; text-color: root.text-color; line-color: root.line-color; clicked => { root.check-room(); } }
                                        ActionButton { label: "启动监听"; primary: true; accent: root.theme-primary; fill: root.card-alt-bg; text-color: root.text-color; line-color: root.line-color; clicked => { root.start-monitor(); } }
                                    }

                                    HorizontalLayout {
                                        spacing: 10px;
                                        ActionButton { label: "停止监听"; accent: root.theme-primary; fill: root.card-alt-bg; text-color: root.text-color; line-color: root.line-color; clicked => { root.stop-monitor(); } }
                                        ActionButton { label: "读取配置"; accent: root.theme-primary; fill: root.card-alt-bg; text-color: root.text-color; line-color: root.line-color; clicked => { root.load-config(); } }
                                        ActionButton {
                                            label: "保存配置"; primary: true; accent: root.theme-primary; fill: root.card-alt-bg; text-color: root.text-color; line-color: root.line-color;
                                            clicked => {
                                                root.save-config(
                                                    root.room-id, root.danmu-len, root.entry-msg, root.goodbye-info,
                                                    root.pk-notice, root.welcome-enabled, root.entry-effect, root.thanks-gift,
                                                    root.thanks-focus, root.thanks-share, root.cron-danmu, root.keyword-reply,
                                                    root.draw-by-lot, root.sign-in-enable,
                                                    root.danmu-filter-enable, root.danmu-filter-words-text,
                                                    root.danmu-filter-repeat-threshold, root.gift-aliases-text,
                                                    root.gift-thanks-templates-text, root.gift-summary-thanks,
                                                    root.gift-summary-template, root.newcomer-danmu-enable,
                                                    root.newcomer-danmu-template, root.permanent-blacklist-users-text,
                                                    root.permanent-blacklist-names-text, root.special-nicknames-text,
                                                    root.robot-name, root.talk-robot-cmd,
                                                    root.robot-mode-index, root.chatgpt-token, root.chatgpt-api-url, root.chatgpt-prompt,
                                                    root.welcome-list-text, root.focus-list-text, root.blacklist-wide-text,
                                                    root.blacklist-exact-text, root.keyword-reply-text, root.cron-danmu-text,
                                                    root.draw-list-text
                                                );
                                            }
                                        }
                                        ActionButton { label: "检查更新"; accent: root.theme-primary; fill: root.card-alt-bg; text-color: root.text-color; line-color: root.line-color; clicked => { root.check-update(); } }
                                    }

                                    HorizontalLayout {
                                        spacing: 10px;
                                        Rectangle {
                                            height: 42px;
                                            border-radius: 14px;
                                            background: root.card-alt-bg;
                                            border-width: 1px;
                                            border-color: root.line-color;

                                            LineEdit {
                                                text <=> root.manual-danmu;
                                                placeholder-text: "输入手动弹幕内容...";
                                                x: 12px;
                                                y: 8px;
                                                width: parent.width - 24px;
                                                height: 24px;
                                            }
                                        }
                                        ActionButton { label: "发送弹幕"; primary: true; accent: root.theme-primary; fill: root.card-alt-bg; text-color: root.text-color; line-color: root.line-color; clicked => { root.send-danmu(root.manual-danmu); } }
                                        ActionButton {
                                            label: "下载更新器";
                                            enabled: root.update-link != "";
                                            accent: root.theme-primary; fill: root.card-alt-bg; text-color: root.text-color; line-color: root.line-color;
                                            clicked => { root.download-update(root.update-link); }
                                        }
                                    }
                                }
                            }

                            Rectangle {
                                background: root.panel-bg;
                                border-radius: 20px;
                                border-width: 1px;
                                border-color: root.line-color;

                                VerticalLayout {
                                    padding: 18px;
                                    spacing: 12px;

                                    Text { text: "自动化功能"; color: root.text-color; font-size: 16px; font-weight: 900; }

                                    HorizontalLayout {
                                        spacing: 12px;
                                        FeatureCard { width: 440px; title: "弹幕欢迎"; desc: "普通用户进入直播间"; meta: "12 条规则"; enabled: root.welcome-enabled; accent: root.theme-primary; base-bg: root.card-alt-bg; outline-color: root.line-color; text-color: root.text-color; muted-color: root.muted-color; }
                                        FeatureCard { width: 440px; title: "舰长欢迎"; desc: "舰长/提督/总督进入"; meta: "3 种模板"; enabled: root.entry-effect; accent: root.theme-primary; base-bg: root.card-alt-bg; outline-color: root.line-color; text-color: root.text-color; muted-color: root.muted-color; }
                                    }
                                    HorizontalLayout {
                                        spacing: 12px;
                                        FeatureCard { width: 440px; title: "礼物答谢"; desc: "收到礼物自动感谢"; meta: "15s 聚合"; enabled: root.thanks-gift; accent: root.theme-primary; base-bg: root.card-alt-bg; outline-color: root.line-color; text-color: root.text-color; muted-color: root.muted-color; }
                                        FeatureCard { width: 440px; title: "AI 机器人"; desc: "智能弹幕对话"; meta: root.robot-mode-index == 1 ? "ChatGPT 模式" : "QingYunKe 模式"; enabled: true; accent: #8b5cf6; base-bg: root.card-alt-bg; outline-color: root.line-color; text-color: root.text-color; muted-color: root.muted-color; }
                                    }
                                    HorizontalLayout {
                                        spacing: 12px;
                                        FeatureCard { width: 440px; title: "秒级定时弹幕"; desc: "按 Cron 精确发送"; meta: root.cron-danmu ? "2 个任务运行中" : "当前关闭"; enabled: root.cron-danmu; accent: #06b6d4; base-bg: root.card-alt-bg; outline-color: root.line-color; text-color: root.text-color; muted-color: root.muted-color; }
                                        FeatureCard { width: 440px; title: "抽签与签到"; desc: "互动命令自动响应"; meta: "抽签 / 签到 / 查询弹幕"; enabled: root.draw-by-lot || root.sign-in-enable; accent: #f59e0b; base-bg: root.card-alt-bg; outline-color: root.line-color; text-color: root.text-color; muted-color: root.muted-color; }
                                    }
                                }
                            }

                            HorizontalLayout {
                                spacing: 16px;

