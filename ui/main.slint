                                        Text { text: "10:00 - 15:00"; color: root.muted-color; font-size: 11px; }
                                        HorizontalLayout {
                                            spacing: 10px;
                                            Rectangle { width: 40px; height: 96px; border-radius: 12px; background: root.line-color; }
                                            Rectangle { width: 40px; height: 120px; border-radius: 12px; background: root.theme-primary; y: 18px; }
                                            Rectangle { width: 40px; height: 142px; border-radius: 12px; background: root.theme-primary; y: 0px; }
                                            Rectangle { width: 40px; height: 112px; border-radius: 12px; background: root.line-color; y: 28px; }
                                            Rectangle { width: 40px; height: 150px; border-radius: 12px; background: root.theme-primary; y: 0px; }
