        if root.theme-popup-open : Rectangle {
            x: 1160px;
            y: 78px;
            width: 332px;
            height: 530px;
            border-radius: 22px;
            background: root.popup-bg;
            border-width: 1px;
            border-color: root.line-color;

            VerticalLayout {
                padding: 18px;
                spacing: 14px;

                HorizontalLayout {
                    Text { text: "主题设置"; color: root.text-color; font-size: 16px; font-weight: 900; }
                    Rectangle { }
                    Rectangle {
                        width: 28px;
                        height: 28px;
                        border-radius: 14px;
                        background: root.card-alt-bg;
                        border-width: 1px;
                        border-color: root.line-color;

                        Text {
                            text: "X";
                            color: root.text-color;
                            font-size: 11px;
                            font-weight: 900;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }

                        TouchArea {
                            clicked => {
                                root.theme-popup-open = false;
                            }
                        }
                    }
                }

                Text { text: "外观模式"; color: root.text-color; font-size: 13px; font-weight: 800; }
                HorizontalLayout {
                    spacing: 10px;
                    Rectangle {
                        height: 42px;
                        border-radius: 14px;
                        background: !root.dark-mode ? root.theme-primary : root.card-alt-bg;
                        border-width: 1px;
                        border-color: !root.dark-mode ? root.theme-primary : root.line-color;

                        Text {
                            text: "浅色";
                            color: !root.dark-mode ? #ffffff : root.text-color;
                            font-size: 12px;
                            font-weight: 800;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }

                        TouchArea { clicked => { root.dark-mode = false; } }
                    }
                    Rectangle {
                        height: 42px;
                        border-radius: 14px;
                        background: root.dark-mode ? root.theme-primary : root.card-alt-bg;
                        border-width: 1px;
                        border-color: root.dark-mode ? root.theme-primary : root.line-color;

                        Text {
                            text: "深色";
                            color: root.dark-mode ? #ffffff : root.text-color;
                            font-size: 12px;
                            font-weight: 800;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }

                        TouchArea { clicked => { root.dark-mode = true; } }
                    }
                }

                Text { text: "6 种主题颜色"; color: root.text-color; font-size: 13px; font-weight: 800; }
                HorizontalLayout {
                    spacing: 8px;
                    ThemeSwatch { width: 98px; swatch: #0ea5e9; label: "海洋蓝"; selected: root.theme-choice == 0; fill: root.card-alt-bg; text-color: root.text-color; line-color: root.line-color; activate => { root.theme-choice = 0; } }
                    ThemeSwatch { width: 98px; swatch: #10b981; label: "翡翠绿"; selected: root.theme-choice == 1; fill: root.card-alt-bg; text-color: root.text-color; line-color: root.line-color; activate => { root.theme-choice = 1; } }
                    ThemeSwatch { width: 98px; swatch: #f97316; label: "日落橙"; selected: root.theme-choice == 2; fill: root.card-alt-bg; text-color: root.text-color; line-color: root.line-color; activate => { root.theme-choice = 2; } }
                }
                HorizontalLayout {
                    spacing: 8px;
                    ThemeSwatch { width: 98px; swatch: #ec4899; label: "兰花粉"; selected: root.theme-choice == 3; fill: root.card-alt-bg; text-color: root.text-color; line-color: root.line-color; activate => { root.theme-choice = 3; } }
                    ThemeSwatch { width: 98px; swatch: #64748b; label: "石板灰"; selected: root.theme-choice == 4; fill: root.card-alt-bg; text-color: root.text-color; line-color: root.line-color; activate => { root.theme-choice = 4; } }
                    ThemeSwatch { width: 98px; swatch: #f59e0b; label: "琥珀金"; selected: root.theme-choice == 5; fill: root.card-alt-bg; text-color: root.text-color; line-color: root.line-color; activate => { root.theme-choice = 5; } }
                }

                Text { text: "自定义色板"; color: root.text-color; font-size: 13px; font-weight: 800; }
                HorizontalLayout {
                    spacing: 8px;
                    ThemeSwatch { width: 68px; swatch: #8b5cf6; label: "紫"; selected: root.theme-choice == 6; fill: root.card-alt-bg; text-color: root.text-color; line-color: root.line-color; activate => { root.theme-choice = 6; } }
                    ThemeSwatch { width: 68px; swatch: #ef4444; label: "红"; selected: root.theme-choice == 7; fill: root.card-alt-bg; text-color: root.text-color; line-color: root.line-color; activate => { root.theme-choice = 7; } }
                    ThemeSwatch { width: 68px; swatch: #14b8a6; label: "青"; selected: root.theme-choice == 8; fill: root.card-alt-bg; text-color: root.text-color; line-color: root.line-color; activate => { root.theme-choice = 8; } }
                    ThemeSwatch { width: 68px; swatch: #a855f7; label: "紫粉"; selected: root.theme-choice == 9; fill: root.card-alt-bg; text-color: root.text-color; line-color: root.line-color; activate => { root.theme-choice = 9; } }
                }
                HorizontalLayout {
                    spacing: 8px;
                    ThemeSwatch { width: 68px; swatch: #22c55e; label: "草绿"; selected: root.theme-choice == 10; fill: root.card-alt-bg; text-color: root.text-color; line-color: root.line-color; activate => { root.theme-choice = 10; } }
                    ThemeSwatch { width: 68px; swatch: #2563eb; label: "靛蓝"; selected: root.theme-choice == 11; fill: root.card-alt-bg; text-color: root.text-color; line-color: root.line-color; activate => { root.theme-choice = 11; } }
                    Rectangle { }
                    Rectangle { }
                }

                Rectangle {
                    border-radius: 18px;
                    background: root.card-alt-bg;
                    border-width: 1px;
                    border-color: root.line-color;

                    VerticalLayout {
                        padding: 14px;
                        spacing: 10px;
                        Text { text: "预览效果"; color: root.text-color; font-size: 12px; font-weight: 800; }
                        Rectangle {
                            height: 36px;
                            border-radius: 12px;
                            background: root.theme-primary;
                            Text {
                                text: "主要按钮";
                                color: #ffffff;
                                font-size: 12px;
                                font-weight: 800;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                        HorizontalLayout {
                            spacing: 10px;
                            Rectangle {
                                width: 40px;
                                height: 22px;
                                border-radius: 11px;
                                background: root.theme-primary;
                                Rectangle { x: 20px; y: 3px; width: 16px; height: 16px; border-radius: 8px; background: #ffffff; }
                            }
                            Rectangle {
                                width: 74px;
                                height: 22px;
                                border-radius: 11px;
                                background: root.theme-primary;
                                Text {
                                    text: "状态标签";
                                    color: #ffffff;
                                    font-size: 10px;
                                    font-weight: 700;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }
                }

                ActionButton { label: "恢复默认"; accent: root.theme-primary; fill: root.card-alt-bg; text-color: root.text-color; line-color: root.line-color; clicked => { root.theme-choice = 0; root.dark-mode = false; } }
            }
        }
    }
}
