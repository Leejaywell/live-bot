                                            LineEdit { text <=> root.talk-robot-cmd; placeholder-text: "触发词"; }
                                            ComboBox { model: ["QingYunKe", "ChatGPT"]; current-index <=> root.robot-mode-index; }
                                            LineEdit { text <=> root.chatgpt-api-url; placeholder-text: "ChatGPT API URL"; }
                                            LineEdit { text <=> root.chatgpt-token; placeholder-text: "ChatGPT API Token"; }
                                            LineEdit { text <=> root.chatgpt-prompt; placeholder-text: "Prompt"; }
                                        }
                                    }
                                }
