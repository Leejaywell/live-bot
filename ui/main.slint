                                        PlanCard { width: 288px; title: "录播与素材"; desc: "自动录播、截图、OBS 网页源和素材管理。"; tags: "视频存档 · 网页源"; accent: root.theme-primary; base-bg: root.card-alt-bg; outline-color: root.line-color; text-color: root.text-color; muted-color: root.muted-color; }
