                                    HorizontalLayout {
                                        spacing: 10px;
                                        Rectangle { height: 32px; width: 96px; border-radius: 16px; background: root.theme-primary; Text { text: "基础配置"; color: #ffffff; font-size: 11px; font-weight: 800; horizontal-alignment: center; vertical-alignment: center; } }
                                        Rectangle { height: 32px; width: 84px; border-radius: 16px; background: root.card-alt-bg; border-width: 1px; border-color: root.line-color; Text { text: "AI 配置"; color: root.text-color; font-size: 11px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; } }
                                        Rectangle { height: 32px; width: 96px; border-radius: 16px; background: root.card-alt-bg; border-width: 1px; border-color: root.line-color; Text { text: "列表规则"; color: root.text-color; font-size: 11px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; } }
                                        Rectangle { height: 32px; width: 96px; border-radius: 16px; background: root.card-alt-bg; border-width: 1px; border-color: root.line-color; Text { text: "运行策略"; color: root.text-color; font-size: 11px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; } }
                                    }

                                    HorizontalLayout {
                                        spacing: 14px;
