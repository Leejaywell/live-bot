                                        PlanCard { width: 288px; title: "用户详情查询"; desc: "拉取观众最近弹幕、送礼和粉丝牌画像。"; tags: "UID 查询 · 粉丝分析"; accent: root.theme-primary; base-bg: root.card-alt-bg; outline-color: root.line-color; text-color: root.text-color; muted-color: root.muted-color; }
                                        PlanCard { width: 288px; title: "更强 PK 分析"; desc: "展示对手房间、助攻数据和 PK 历史。"; tags: "胜率预测 · 对手分析"; accent: root.theme-primary; base-bg: root.card-alt-bg; outline-color: root.line-color; text-color: root.text-color; muted-color: root.muted-color; }
